# Template for the frontend's .env. Copy to .env and adjust if needed.
# Local dev only. Vite reads this for vite.config.ts (server.proxy target).
# Runtime code never sees VITE_PROXY_TARGET — axios uses the relative baseURL "/api"
# and Vite's dev proxy forwards /api/* and /images/* to this target.
VITE_PROXY_TARGET=http://localhost:8080
