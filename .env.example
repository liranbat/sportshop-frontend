# Template — copy to .env (dev) or .env.prod (Docker prod). Both are gitignored;
# same suffix on both sides, only the prefix differs (VITE_APP_ in dev because
# Vite requires the VITE_ prefix to expose values to client code; plain APP_ in
# prod because docker-compose feeds container env directly, no Vite involvement).
#
# Add a new value: add VITE_APP_FOO here (in .env) and APP_FOO in .env.prod. No
# other file changes needed — src/config.ts and entrypoint.sh discover keys by
# prefix. Reads at call sites are `config.FOO` (uppercase; matches the suffix).

# PROXY_TARGET is used by vite.config.ts for the dev-server proxy. Not present
# in .env.prod because Caddy handles proxying in prod.
VITE_APP_PROXY_TARGET=http://localhost:8080

VITE_APP_ENV_LABEL=dev

# Example prod value (in .env.prod, APP_ prefix instead of VITE_APP_):
#   APP_ENV_LABEL=prod
